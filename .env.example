# Credenciales Geotab
GEOTAB_USERNAME=tu_usuario@empresa.com
GEOTAB_PASSWORD=tu_contraseña
GEOTAB_DATABASE=nombre_base_geotab

# GPSWox / Rastrear GPS (173.212.203.163)
GPSWOX_EMAIL=gerencia@rastrear.com.co
GPSWOX_PASSWORD=tu_contraseña_gpswox

# plataforma.sistemagps.online
PLATAFORMA_EMAIL=gerencia@rastrear.com.co
PLATAFORMA_PASSWORD=tu_contraseña_plataforma
# Dias de historial a cargar al arrancar (0=no cargar, 7=ultima semana)
PLATAFORMA_HISTORY_DAYS=0

# Puerto Flask (5000 en produccion, 5003 local si hay conflicto)
APP_PORT=5000

# PostgreSQL (para desarrollo local)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=geotab_gps
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
